<h1>
  Category #<%= @the_category.id %> details
</h1>

<article>
  <div>
    <a href="/categories">
      Go back
    </a>
  </div>

  <div>
    <a href="/delete_category/<%= @the_category.id %>">
      Delete category
    </a>
  </div>
  <dl>
    <dt>
      Name
    </dt>
    <dd>
      <%= @the_category.name %>
    </dd>

    <dt>
      Household
    </dt>
    <dd>
      <%= @the_category.household_id %>
    </dd>

    <dt>
      Created at
    </dt>
    <dd>
      <%= time_ago_in_words(@the_category.created_at) %> ago
    </dd>

    <dt>
      Updated at
    </dt>
    <dd>
      <%= time_ago_in_words(@the_category.updated_at) %> ago
    </dd>
  </dl>
</article>

<hr>


<article>
  <header>
    <h2>
      Edit category
    </h2>
  </header>

  <form action="/modify_category/<%= @the_category.id %>"  method="post" >
    <div>
      <label for="name_box">
        Name
      </label>

      <input type="text" id="name_box" name="query_name" value="<%= @the_category.name %>">
    </div>

    <div>
      <label for="household_id_box">
        Household
      </label>

      <input type="text" id="household_id_box" name="query_household_id" value="<%= @the_category.household_id %>">
    </div>

    <button type="submit">
      Update category
    </button>
  </form>
</article>

<hr>
