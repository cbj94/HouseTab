<h1>
  List of all households
</h1>

<hr>

<article>
  <header>
    <h2>
      Add a new household
    </h2>
  </header>

  <form action="/insert_household" method="post">
    <div>
      <label for="name_box">
        Name
      </label>

      <input type="text" id="name_box" name="query_name">
    </div>

    <button type="submit">
      Create household
    </button>
  </form>
</article>

<hr>

<article>
  <ul>
    <% @list_of_households.each do |a_household| %>
      <li>
        <a href="/households/<%= a_household.id %>">
          Household #<%= a_household.id %>
        </a>
      </li>
    <% end %>
  </ul>
</article>

<hr>
