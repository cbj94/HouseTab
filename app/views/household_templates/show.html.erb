<h1><%= @the_household.name %></h1>

<nav>
  <ul>
    <li><a href="/">Home</a></li>
  </ul>
  <ul>
    <li><a href="#members">Members</a></li>
    <li><a href="#balances">Balances</a></li>
    <li><a href="#spending">Spending</a></li>
    <li><a href="#expenses">Expenses</a></li>
    <li><a href="#add-expense">Add Expense</a></li>
    <li><a href="#settle-up">Settle Up</a></li>
    <li><a href="#settlements">Settlements</a></li>
    <% if @membership.role == "creator" %>
      <li><a href="/delete_household/<%= @the_household.id %>" style="color: red;">Delete</a></li>
    <% end %>
  </ul>
</nav>

<hr>

<h2 id="members">Members (<%= @members.count %>)</h2>
<% @members.each do |member| %>
  <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 5px;">
    <span><%= member.first_name %> <%= member.last_name %></span>
    <% membership = Membership.where({ :user_id => member.id, :household_id => @the_household.id }).at(0) %>
    <% if membership.role == "creator" %>
      <small style="opacity: 0.6;">(creator)</small>
    <% elsif @membership.role == "creator" && member.id != current_user.id %>
      <a href="/delete_membership/<%= membership.id %>" title="Remove <%= member.first_name %>"
         style="color: gray; text-decoration: none; font-size: 0.9em; opacity: 0.5;"
         onclick="return confirm('Remove <%= member.first_name %> from this household?')">×</a>
    <% end %>
  </div>
<% end %>

<% if @membership.role == "creator" %>
  <br>
  <h3>Add a Member</h3>
  <form action="/insert_membership" method="post">
    <input type="hidden" name="query_household_id" value="<%= @the_household.id %>">
    <input type="hidden" name="query_role" value="member">
    <div>
      <label for="email">Roommate's Email</label><br>
      <input type="email" id="email" name="query_email" placeholder="e.g. bob@example.com">
    </div>
    <br>
    <button type="submit">Add Member</button>
  </form>
<% end %>

<hr>

<h2 id="balances">Balances</h2>
<% if @balances.empty? %>
  <p>No other members yet.</p>
<% else %>
  <% @balances.each do |member, amount| %>
    <div style="border: 1px solid #ccc; padding: 10px; margin-bottom: 10px;">
      <% if amount > 0 %>
        <span style="color: red;">You owe <strong><%= member.first_name %></strong> $<%= sprintf('%.2f', amount) %></span>
      <% elsif amount < 0 %>
        <span style="color: green;"><strong><%= member.first_name %></strong> owes you $<%= sprintf('%.2f', amount.abs) %></span>
      <% else %>
        <span>You and <strong><%= member.first_name %></strong> are settled up!</span>
      <% end %>
    </div>
  <% end %>
<% end %>

<hr>

<h2 id="spending">Spending by Category</h2>
<% if @total_spending == 0 %>
  <p>No spending data yet.</p>
<% else %>
  <table>
    <thead>
      <tr>
        <th>Category</th>
        <th style="text-align: right;">Total</th>
        <th style="text-align: right;">% of Spending</th>
      </tr>
    </thead>
    <tbody>
      <% @category_totals.each do |name, total| %>
        <tr>
          <td><%= name %></td>
          <td style="text-align: right;">$<%= sprintf('%.2f', total) %></td>
          <td style="text-align: right;"><%= sprintf('%.0f', (total / @total_spending) * 100) %>%</td>
        </tr>
      <% end %>
    </tbody>
    <tfoot>
      <tr>
        <td><strong>Total</strong></td>
        <td style="text-align: right;"><strong>$<%= sprintf('%.2f', @total_spending) %></strong></td>
        <td style="text-align: right;"><strong>100%</strong></td>
      </tr>
    </tfoot>
  </table>
<% end %>

<hr>

<h2 id="expenses">Recent Expenses</h2>

<% if @expenses.count == 0 %>
  <p>No expenses yet. Add one below!</p>
<% else %>
  <% @expenses.each do |expense| %>
    <div style="border: 1px solid #ccc; padding: 10px; margin-bottom: 10px;">
      <strong><%= expense.description %></strong> — $<%= sprintf('%.2f', expense.total_amount) %><br>
      Paid by: <%= expense.payer.first_name %> <%= expense.payer.last_name %><br>
      Category: <%= expense.category.name %><br>
      Date: <%= expense.date.strftime("%B %d, %Y") %><br>
      Split among: <%= expense.beneficiaries.map { |u| u.first_name }.join(", ") %><br>
      <% if expense.notes.present? %>
        Notes: <%= expense.notes %><br>
      <% end %>
      <a href="/expenses/<%= expense.id %>">View details</a>
    </div>
  <% end %>
<% end %>

<hr>

<h2 id="add-expense">Add an Expense</h2>
<form action="/insert_expense" method="post">
  <input type="hidden" name="query_household_id" value="<%= @the_household.id %>">
  <input type="hidden" name="query_payer_id" value="<%= current_user.id %>">

  <div>
    <label for="description">Description</label><br>
    <input type="text" id="description" name="query_description" placeholder="e.g. Costco run">
  </div>

  <div>
    <label for="total_amount">Total Amount ($)</label><br>
    <input type="number" id="total_amount" name="query_total_amount" step="0.01" min="0">
  </div>

  <div>
    <label for="date">Date</label><br>
    <input type="date" id="date" name="query_date" value="<%= Date.today %>">
  </div>

  <div>
    <label for="category_id">Category</label><br>
    <select id="category_id" name="query_category_id">
      <% Category.where({ :household_id => nil }).each do |cat| %>
        <option value="<%= cat.id %>"><%= cat.name %></option>
      <% end %>
    </select>
  </div>

  <div>
    <label for="notes">Notes (optional)</label><br>
    <input type="text" id="notes" name="query_notes">
  </div>

  <div>
    <label>Split among:</label><br>
    <% @members.each do |member| %>
      <input type="checkbox" name="split_user_ids[]" value="<%= member.id %>" checked>
      <%= member.first_name %> <%= member.last_name %><br>
    <% end %>
  </div>

  <br>
  <button type="submit">Add Expense</button>
</form>

<hr>

<h2 id="settle-up">Settle Up</h2>
<form action="/insert_settlement" method="post">
  <input type="hidden" name="query_household_id" value="<%= @the_household.id %>">
  <input type="hidden" name="query_payer_id" value="<%= current_user.id %>">

  <div>
    <label for="payee_id">Pay</label><br>
    <select id="payee_id" name="query_payee_id">
      <option value="">Choose who to pay...</option>
      <% @members.each do |member| %>
        <% if member.id != current_user.id %>
          <option value="<%= member.id %>"><%= member.first_name %> <%= member.last_name %></option>
        <% end %>
      <% end %>
    </select>
  </div>

  <div>
    <label for="amount">Amount ($)</label><br>
    <input type="number" id="amount" name="query_amount" step="0.01" min="0">
  </div>

  <div>
    <label for="settlement_date">Date</label><br>
    <input type="date" id="settlement_date" name="query_date" value="<%= Date.today %>">
  </div>

  <div>
    <label for="settlement_notes">Notes (optional)</label><br>
    <input type="text" id="settlement_notes" name="query_notes" placeholder="e.g. For the Costco run">
  </div>

  <br>
  <button type="submit">Record Payment</button>
</form>

<hr>

<h2 id="settlements">Recent Settlements</h2>
<% if @settlements.count == 0 %>
  <p>No settlements yet.</p>
<% else %>
  <% @settlements.each do |settlement| %>
    <div style="border: 1px solid #ccc; padding: 10px; margin-bottom: 10px;">
      <strong><%= settlement.payer.first_name %></strong> paid
      <strong><%= settlement.payee.first_name %></strong>
      — $<%= sprintf('%.2f', settlement.amount) %><br>
      Date: <%= settlement.date.strftime("%B %d, %Y") %><br>
      <% if settlement.notes.present? %>
        Notes: <%= settlement.notes %><br>
      <% end %>
    </div>
  <% end %>
<% end %>
