<h1><%= @the_expense.description %></h1>

<nav>
  <a href="/households/<%= @the_expense.household_id %>">Back to <%= @the_expense.household.name %></a>
</nav>

<hr>

<article>
  <table>
    <tbody>
      <tr>
        <td><strong>Amount</strong></td>
        <td>$<%= sprintf('%.2f', @the_expense.total_amount) %></td>
      </tr>
      <tr>
        <td><strong>Paid by</strong></td>
        <td><%= @the_expense.payer.first_name %> <%= @the_expense.payer.last_name %></td>
      </tr>
      <tr>
        <td><strong>Category</strong></td>
        <td><%= @the_expense.category.name %></td>
      </tr>
      <tr>
        <td><strong>Date</strong></td>
        <td><%= @the_expense.date.strftime("%B %d, %Y") %></td>
      </tr>
      <% if @the_expense.notes.present? %>
        <tr>
          <td><strong>Notes</strong></td>
          <td><%= @the_expense.notes %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</article>

<hr>

<h2>Split Breakdown</h2>
<table>
  <thead>
    <tr>
      <th>Person</th>
      <th style="text-align: right;">Owes</th>
    </tr>
  </thead>
  <tbody>
    <% @the_expense.expense_splits.each do |split| %>
      <tr>
        <td><%= split.user.first_name %> <%= split.user.last_name %></td>
        <td style="text-align: right;">$<%= sprintf('%.2f', split.amount_owed) %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<hr>

<% if @the_expense.payer_id == current_user.id %>
  <a href="/delete_expense/<%= @the_expense.id %>" style="color: red;"
     onclick="return confirm('Delete this expense? This cannot be undone.')">Delete this expense</a>
<% end %>

