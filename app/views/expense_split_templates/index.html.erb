<h1>
  List of all expense splits
</h1>

<hr>

<article>
  <header>
    <h2>
      Add a new expense split
    </h2>
  </header>

  <form action="/insert_expense_split" method="post">
    <div>
      <label for="expense_id_box">
        Expense
      </label>

      <input type="text" id="expense_id_box" name="query_expense_id">
    </div>

    <div>
      <label for="user_id_box">
        User
      </label>

      <input type="text" id="user_id_box" name="query_user_id">
    </div>

    <div>
      <label for="amount_owed_box">
        Amount owed
      </label>

      <input type="text" id="amount_owed_box" name="query_amount_owed">
    </div>

    <button type="submit">
      Create expense split
    </button>
  </form>
</article>

<hr>

<article>
  <ul>
    <% @list_of_expense_splits.each do |an_expense_split| %>
      <li>
        <a href="/expense_splits/<%= an_expense_split.id %>">
          Expense split #<%= an_expense_split.id %>
        </a>
      </li>
    <% end %>
  </ul>
</article>

<hr>
